{
  "uid": "service-overview",
  "title": "Service Overview",
  "description": "全部服務的 RED metrics（Rate / Error / Duration）總覽",
  "tags": ["observability", "RED", "services"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(traces_spanmetrics_calls_total, service)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "span_kind",
        "label": "Span Kind",
        "type": "custom",
        "query": "SPAN_KIND_SERVER,SPAN_KIND_CLIENT,SPAN_KIND_PRODUCER,SPAN_KIND_CONSUMER",
        "multi": true,
        "includeAll": true,
        "current": { "text": "SPAN_KIND_SERVER", "value": ["SPAN_KIND_SERVER"] }
      }
    ]
  },
  "panels": [
    {
      "title": "Total Request Rate",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=~\"$span_kind\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "steps": [{ "value": 0, "color": "green" }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=~\"$span_kind\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=~\"$span_kind\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "title": "Avg Latency",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_latency_sum{service=~\"$service\", span_kind=~\"$span_kind\"}[$__rate_interval])) / sum(rate(traces_spanmetrics_latency_count{service=~\"$service\", span_kind=~\"$span_kind\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "yellow" }, { "value": 5, "color": "red" }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "title": "Active Services",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(count by (service)(traces_spanmetrics_calls_total{service=~\"$service\"}))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "value": 0, "color": "blue" }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "title": "Request Rate by Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service)(rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=~\"$span_kind\"}[$__rate_interval]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 4, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service)(rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=~\"$span_kind\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum by (service)(rate(traces_spanmetrics_calls_total{service=~\"$service\", span_kind=~\"$span_kind\"}[$__rate_interval]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "title": "P95 Latency by Service",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (service, le)(rate(traces_spanmetrics_latency_bucket{service=~\"$service\", span_kind=~\"$span_kind\"}[$__rate_interval])))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "title": "Service-to-Service Traffic",
      "description": "服務間呼叫關係與流量。完整互動式 Service Map 請至 Grafana Explore → Tempo → Service Graph",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (client, server)(rate(traces_service_graph_request_total[$__rate_interval]))",
          "legendFormat": "{{client}} → {{server}}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "options": { "orientation": "horizontal", "xTickLabelRotation": 0 }
    },
    {
      "title": "Service-to-Service Latency",
      "description": "服務間平均回應時間",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (client, server)(rate(traces_service_graph_request_server_seconds_sum[$__rate_interval])) / sum by (client, server)(rate(traces_service_graph_request_server_seconds_count[$__rate_interval]))",
          "legendFormat": "{{client}} → {{server}}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "options": { "orientation": "horizontal", "xTickLabelRotation": 0 }
    },
    {
      "title": "Latency Percentiles (All Services)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(traces_spanmetrics_latency_bucket{service=~\"$service\", span_kind=~\"$span_kind\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le)(rate(traces_spanmetrics_latency_bucket{service=~\"$service\", span_kind=~\"$span_kind\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(traces_spanmetrics_latency_bucket{service=~\"$service\", span_kind=~\"$span_kind\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 5 } }
      }
    },
    {
      "title": "Service-to-Service Call Rate",
      "type": "table",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (client, server)(rate(traces_service_graph_request_total[$__rate_interval]))",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "transformations": [
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }
      ]
    },
    {
      "title": "Errors by Service & Operation",
      "type": "table",
      "gridPos": { "x": 0, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service, span_name)(rate(traces_spanmetrics_calls_total{service=~\"$service\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval]))",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "transformations": [
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }
      ]
    },
    {
      "title": "Service-to-Service Failure Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (client, server)(rate(traces_service_graph_request_failed_total[$__rate_interval])) / sum by (client, server)(rate(traces_service_graph_request_total[$__rate_interval]))",
          "legendFormat": "{{client}} → {{server}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "fillOpacity": 10 } }
      }
    }
  ],
  "schemaVersion": 39
}
