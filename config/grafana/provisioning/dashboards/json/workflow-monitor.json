{
  "uid": "workflow-monitor",
  "title": "Workflow Monitor",
  "description": "BettingWorkflow / DepositWorkflow / WithdrawalWorkflow 執行監控",
  "tags": ["observability", "workflow"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "workflow",
        "label": "Workflow",
        "type": "custom",
        "query": "BettingWorkflow,DepositWorkflow,WithdrawalWorkflow",
        "multi": false,
        "includeAll": false,
        "current": { "text": "BettingWorkflow", "value": "BettingWorkflow" }
      }
    ]
  },
  "panels": [
    {
      "title": "Execution Rate",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"ApiGateway\", span_name=\"$workflow\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "steps": [{ "value": 0, "color": "green" }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"ApiGateway\", span_name=\"$workflow\", span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_spanmetrics_calls_total{service=\"ApiGateway\", span_name=\"$workflow\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.05, "color": "yellow" },
              { "value": 0.10, "color": "red" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "title": "Avg Duration",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_latency_sum{service=\"ApiGateway\", span_name=\"$workflow\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])) / sum(rate(traces_spanmetrics_latency_count{service=\"ApiGateway\", span_name=\"$workflow\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 3, "color": "yellow" }, { "value": 10, "color": "red" }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "title": "P99 Duration",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(traces_spanmetrics_latency_bucket{service=\"ApiGateway\", span_name=\"$workflow\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [{ "value": 0, "color": "blue" }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "title": "Execution Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"ApiGateway\", span_name=\"$workflow\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))",
          "legendFormat": "Total"
        },
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"ApiGateway\", span_name=\"$workflow\", span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval]))",
          "legendFormat": "Errors"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Errors" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "Duration Percentiles",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le)(rate(traces_spanmetrics_latency_bucket{service=\"ApiGateway\", span_name=\"$workflow\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le)(rate(traces_spanmetrics_latency_bucket{service=\"ApiGateway\", span_name=\"$workflow\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le)(rate(traces_spanmetrics_latency_bucket{service=\"ApiGateway\", span_name=\"$workflow\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 5 } }
      }
    },
    {
      "title": "Avg Latency per Operation Step",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (span_name)(rate(traces_spanmetrics_latency_sum{span_kind=\"SPAN_KIND_SERVER\", span_name!~\"BettingWorkflow|DepositWorkflow|WithdrawalWorkflow\"}[$__rate_interval])) / sum by (span_name)(rate(traces_spanmetrics_latency_count{span_kind=\"SPAN_KIND_SERVER\", span_name!~\"BettingWorkflow|DepositWorkflow|WithdrawalWorkflow\"}[$__rate_interval]))",
          "legendFormat": "{{span_name}}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "options": { "orientation": "horizontal", "xTickLabelRotation": 0 }
    },
    {
      "title": "Workflow Execution Rate Comparison",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (span_name)(rate(traces_spanmetrics_calls_total{service=\"ApiGateway\", span_name=~\"BettingWorkflow|DepositWorkflow|WithdrawalWorkflow\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))",
          "legendFormat": "{{span_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "title": "Workflow Error Rate Comparison",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (span_name)(rate(traces_spanmetrics_calls_total{service=\"ApiGateway\", span_name=~\"BettingWorkflow|DepositWorkflow|WithdrawalWorkflow\", span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum by (span_name)(rate(traces_spanmetrics_calls_total{service=\"ApiGateway\", span_name=~\"BettingWorkflow|DepositWorkflow|WithdrawalWorkflow\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))",
          "legendFormat": "{{span_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "fillOpacity": 10 } }
      }
    },
    {
      "title": "Recent Traces",
      "type": "table",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{name=\"$workflow\"}",
          "limit": 20
        }
      ]
    }
  ],
  "schemaVersion": 39
}
